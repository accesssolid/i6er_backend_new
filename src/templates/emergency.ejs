<!DOCTYPE html>
<html>
  <head>
    <title>Emergency Notification</title>
  </head>
  <body
    style="
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
      margin: 0;
      padding: 0;
    "
  >
    <div
      style="
        width: 600px;
        text-align: center;
        margin: 0 auto;
        padding: 20px;
        background-color: #ffffff;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
      "
    >
      <div style="text-align: center; padding: 10px">
        <img
          src="cid:<%= cidLogo %>"
          alt="logo"
          style="max-height: 75px; max-width: 75px"
        />
      </div>

      <span
        style="
          font-weight: 700;
          font-size: 22px;
          text-align: center;
          margin-top: 20px;
        "
      >
        Dear <%= emergency_contact_name %>,
      </span>

      <p
        style="
          font-weight: bold;
          font-family: Arial;
          font-size: 16px;
          text-align: center;
          margin-top: 20px;
        "
      >
        I am writing to inform you that <%= user_name %> has recently made a call to the
        emergency number. Please be prepared for possible medical assistance.
        Their current location is: <%= location %>.
      </p>

      <p
        style="
          font-family: Arial;
          font-size: 14px;
          text-align: center;
          margin-top: 20px;
        "
      >
        Below are the critical medical details you need to know. Please take
        immediate action as required.
        <br /><br />
      </p>
      <div>
        <div style="width: 80%; text-align: left; margin: 5px auto; font-size: 14px">
          <strong>Blood Group:</strong> <%= blood_group ? blood_group : 'Unknown' %> <br /><br />
          <strong>Age:</strong> <%= age ? age + ' years' : 'Not specified' %> <br /><br />
          <strong>Allergies:</strong> <%= allergies.length > 0 ? allergies.join(', ') : 'None' %> <br /><br />
          <strong>Medications</strong>
        </div>

        <table
          style="
            width: 80%;
            margin: 5px auto;
            border-collapse: collapse;
            text-align: left;
            font-family: Arial, sans-serif;
            font-size: 14px;
          "
        >
          <thead>
            <tr style="background-color: #f2f2f2">
              <th style="padding: 10px; border: 1px solid #ddd">Name</th>
              <th style="padding: 10px; border: 1px solid #ddd">Dose</th>
              <th style="padding: 10px; border: 1px solid #ddd">Reason</th>
            </tr>
          </thead>
          <tbody>
            <% if (medications.length > 0) { %>
              <% medications.forEach(function(medication) { %>
                <tr>
                  <td style="padding: 10px; border: 1px solid #ddd"><%= medication.name %></td>
                  <td style="padding: 10px; border: 1px solid #ddd"><%= medication.dose %></td>
                  <td style="padding: 10px; border: 1px solid #ddd"><%= medication.reason %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="3" style="padding: 10px; border: 1px solid #ddd; text-align: center;">
                  No medications listed
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <p
        style="
          font-family: Arial;
          font-size: 14px;
          text-align: center;
          margin-top: 20px;
        "
      >
        Feel free to reach out if you need further assistance or information.
      </p>

      <p>
        Best regards, <br />
        <%= project_name %> Emergency Response Team
      </p>
    </div>
  </body>
</html>